# Harness Engineering EditorConfig
# 由 `he init` 自动生成
# 文档: https://editorconfig.org

root = true

# ─── 全局默认 ───
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# ─── TypeScript / JavaScript ───
[*.{ts,tsx,js,jsx}]
indent_size = 2

# ─── Rust ───
[*.rs]
indent_size = 4

# ─── Makefile ───
[Makefile]
indent_style = tab

# ─── Markdown ───
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ─── YAML ───
[*.{yaml,yml}]
indent_size = 2

# ─── JSON ───
[*.json]
indent_size = 2

# ─── Shell ───
[*.sh]
indent_size = 2

# ─── TOML ───
[*.toml]
indent_size = 2
