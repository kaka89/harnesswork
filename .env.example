# ═══════════════════════════════════════════
# Harness Engineering 环境变量模板
# 由 `he init` 自动生成
#
# 使用方式:
#   1. 复制此文件为 .env:  cp .env.example .env
#   2. 填入实际值
#   3. .env 已在 .gitignore 中，不会被提交
# ═══════════════════════════════════════════

# ─── 应用基本信息 ───
APP_NAME=harnesswork
APP_ENV=dev                              # dev | staging | prod

# ─── OpenWork / OpenCode ───
OPENWORK_DEV_MODE=1                      # 本地开发隔离模式
OPENCODE_VERSION=                        # 锁定 opencode CLI 版本（留空则用 constants.json 中的）

# ─── Harness CI/CD ───
# HARNESS_API_TOKEN=                     # Harness API Token（CI 自动注入，本地不需要）
# HARNESS_ACCOUNT_ID=
# HARNESS_ORG_ID=harnesswork
# HARNESS_PROJECT_ID=harnesswork

# ─── 安全合规工具 ───
# COSIGN_EXPERIMENTAL=1                  # Cosign Keyless 签名模式
# SONARQUBE_URL=https://sonar.company.com
# SONARQUBE_TOKEN=
